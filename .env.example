# Supabase 설정 (Supabase 대시보드 > Settings > API에서 복사)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# JWT 시크릿 (생성: openssl rand -base64 32)
JWT_SECRET=랜덤한_긴_문자열_32자_이상

# 관리자 초기 계정 (첫 로그인 시 자동 bcrypt 암호화)
ADMIN_USERNAME=16242
ADMIN_PASSWORD=your_password

# (선택) 회사 IP만 접속 허용 - 콤마 구분
# ALLOWED_IPS=123.456.789.0,234.567.890.1
